OTLET_DATABASE_URL=postgresql://otlet_worker:replace-me@database.example:5432/app?sslmode=verify-full&sslrootcert=/run/secrets/rds-ca.pem
OTLET_PORTABLE_WORKER_ID=customer-vpc-worker
OTLET_PORTABLE_PROTOCOL_VERSION=1
OTLET_PORTABLE_RUNTIME_IDENTITY_HASH=replace-with-registered-sha256
OTLET_MODEL_NAME=qwen35_4b
OTLET_MODEL_PATH=/models/Qwen3.5-4B-Q4_K_M.gguf
OTLET_MODEL_SHA256=replace-with-registered-model-sha256
OTLET_PORTABLE_RUNTIME_DIR=/tmp
OTLET_PORTABLE_REQUIRE_TLS=1
OTLET_PORTABLE_EGRESS_MODE=deny_model_providers
OTLET_PORTABLE_POLL_MS=1000
OTLET_PORTABLE_RENEW_MS=1000
OTLET_LLAMA_THREADS=4
